# ──────────────────────────────────────────
# Python / Backend
# ──────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.egg
.eggs/

# Virtual environments
backend/venv/
backend/.venv/
venv/
.venv/

# Environment variables (NEVER commit these)
backend/.env
.env
*.env

# SQLite databases
backend/*.db
backend/*.db-shm
backend/*.db-wal
*.db
*.db-shm
*.db-wal

# Generated PDF reports
backend/reports/*.pdf
backend/reports/temp_images/*.png

# Logs
*.log
logs/

# ──────────────────────────────────────────
# Node / Frontend
# ──────────────────────────────────────────
frontend/node_modules/
node_modules/
frontend/dist/
dist/

# Package manager lock files (keep package-lock.json, ignore yarn.lock if not used)
# frontend/package-lock.json  ← keep this

# ──────────────────────────────────────────
# IDE / OS
# ──────────────────────────────────────────
.vscode/settings.json
.idea/
*.DS_Store
Thumbs.db
desktop.ini

# ──────────────────────────────────────────
