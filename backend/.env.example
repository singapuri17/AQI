# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./air_quality.db

# ── JWT ─────────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Real-time AQI — OpenWeatherMap Air Pollution API (FREE tier) ────────────
# Get your key at: https://home.openweathermap.org/api_keys
# Endpoint used: https://api.openweathermap.org/data/2.5/air_pollution
WEATHER_API_KEY=your-openweathermap-api-key-here

# ── Optional: WAQI (World Air Quality Index) API ────────────────────────────
# Get token at: https://aqicn.org/data-platform/token/
# Used as a secondary source if OpenWeatherMap is unavailable
WAQI_API_KEY=

# ── Optional: Google Gemini (for AI recommendations) ────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── Optional: OpenAQ (additional real-time sensor data) ─────────────────────
OPENAQ_API_KEY=your-openaq-api-key-here

# ── AQI refresh interval (minutes) ──────────────────────────────────────────
AQI_REFRESH_INTERVAL_MINUTES=30
